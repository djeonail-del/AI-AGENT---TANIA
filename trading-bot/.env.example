# Copy to .env and fill in. DO NOT commit .env.

# Binance Futures Testnet (https://testnet.binancefuture.com)
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
BINANCE_TESTNET_REST_BASE=https://testnet.binancefuture.com
BINANCE_TESTNET_WSS_BASE=wss://fstream.binancefuture.com

# Bot parameters (all have safe defaults in bot.py)
BOT_LEVERAGE=2
BOT_POSITION_SIZE_PCT=0.10
BOT_STOP_LOSS_PCT=0.01
BOT_TAKE_PROFIT_PCT=0.02
BOT_MAX_DD_PCT=0.05
BOT_POLL_INTERVAL=30

# Paths (inside container)
BOT_DB_PATH=/app/db/trades.db
BOT_LOG_PATH=/app/db/bot.log
RESEARCH_LOG_PATH=/app/db/research.log
